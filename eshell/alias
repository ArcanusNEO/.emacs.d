alias ls ls --color=auto --group-directories-first $*
alias l ls -Fhla $*
alias ll ls -FhlaX $*
alias la ls -FhlaSr $*
alias lt ls -Fhlatr $*
alias lv ls -Fhlav $*
alias diff diff --color=auto $*
alias grep grep --color=auto $*
alias ip ip -color=auto $*
alias j cd $*
alias vi vim $*
alias md mkdir -p $*
alias cls clear $*
